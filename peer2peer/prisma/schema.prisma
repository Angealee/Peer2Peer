generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  role        String
  evaluations Evaluation[]
  sections    Section[]
}

model Section {
  id                 Int                 @id @default(autoincrement())
  name               String
  description        String?
  createdBy          Int
  createdAt          DateTime            @default(now())
  evaluationSections EvaluationSection[]
  instructor         User                @relation(fields: [createdBy], references: [id])
  students           Student[]
}

model Student {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String
  studentId           String
  sectionId           Int
  evaluationsReceived EvaluationResponse[] @relation("Evaluated")
  evaluationsGiven    EvaluationResponse[] @relation("Evaluator")
  section             Section              @relation(fields: [sectionId], references: [id])
}

model Evaluation {
  id          Int                  @id @default(autoincrement())
  title       String
  description String?
  deadline    DateTime?
  anonymous   Boolean              @default(true)
  createdBy   Int
  createdAt   DateTime             @default(now())
  instructor  User                 @relation(fields: [createdBy], references: [id])
  criteria    EvaluationCriteria[]
  responses   EvaluationResponse[]
  sections    EvaluationSection[]
}

model EvaluationCriteria {
  id            Int                  @id @default(autoincrement())
  criterionName String
  evaluationId  Int
  scoreOptions  String?
  evaluation    Evaluation           @relation(fields: [evaluationId], references: [id])
  responses     EvaluationResponse[]
}

model EvaluationResponse {
  id                 Int                @id @default(autoincrement())
  evaluationId       Int
  evaluatorStudentId Int
  evaluatedStudentId Int
  criterionId        Int
  score              Int
  comment            String?
  criterion          EvaluationCriteria @relation(fields: [criterionId], references: [id])
  evaluatedStudent   Student            @relation("Evaluated", fields: [evaluatedStudentId], references: [id])
  evaluation         Evaluation         @relation(fields: [evaluationId], references: [id])
  evaluatorStudent   Student            @relation("Evaluator", fields: [evaluatorStudentId], references: [id])
}

model EvaluationSection {
  id           Int        @id @default(autoincrement())
  evaluationId Int
  sectionId    Int
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id])
  section      Section    @relation(fields: [sectionId], references: [id])
}
